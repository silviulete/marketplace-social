# Piața Continuă — variabile de mediu (Etapa 11)
# Copiază în `.env` (dev) sau setează-le în Vercel (pilot).

# Baza de date: SQLite în dev; la pilot → Postgres (ex. Neon/Vercel Postgres)
DATABASE_URL="file:./dev.db"

# AI (deciziile #41/#43): implicit mock (determinist). Pentru modelul cloud (Google
# AI Studio, implicit gemini-flash-lite-latest — rapid și curat, vezi #43):
#  1. ia o cheie gratuită de la https://aistudio.google.com/apikey
#  2. decomentează liniile de mai jos
# NEXT_PUBLIC_MODEL_PROVIDER="cloud"
# GOOGLE_AI_API_KEY="cheia-ta"
# AI_MODEL="gemini-flash-lite-latest"

# Notificări (decizia #41: email întâi; simulat până la deploy)
# NOTIFY_PROVIDER="resend"
# RESEND_API_KEY="cheia-ta"

# Protecția endpoint-ului /api/tick (#42): obligatoriu la deploy.
# Vercel Cron trimite automat antetul „Authorization: Bearer <CRON_SECRET>".
# CRON_SECRET="un-sir-lung-aleator"
